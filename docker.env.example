# 필수 환경변수 (실사용 시 docker.env 로 복사하여 값 설정)

# PostgreSQL 연결 문자열: compose의 postgres 서비스로 연결
POSTGRES_URI=postgresql://postgres:postgres@postgres:5432/modol
# 또는 DATABASE_URL 사용 가능
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/modol

# 데이터베이스 자동 초기화 설정 (기본값: false)
# true로 설정하면 컨테이너 시작 시 자동으로 DB 스키마를 생성합니다.
# false로 설정하면 수동으로 'yarn setup-postgres' 명령을 실행해야 합니다.
# AUTO_INIT_DB=false

# JWT 서명용 비밀값 (임의의 안전한 랜덤 문자열로 교체하세요)
JWT_SECRET=please-change-this-to-a-strong-secret

# Ollama 엔드포인트 (Ollama 서비스를 사용할 경우)
# 로컬 호스트에서 접근 시: http://ollama:11434 (컨테이너 간)
# 호스트에서 직접 실행된 Ollama를 사용할 경우: http://host.docker.internal:11434
OLLAMA_ENDPOINTS=http://ollama:11434

# 모델 서버 호출 타임아웃 설정 (밀리초)
# 스트리밍 요청 타임아웃 (기본값: 900000ms = 15분)
# MODEL_SERVER_TIMEOUT_STREAM=900000

# 일반 요청 타임아웃 (기본값: 600000ms = 10분)
# MODEL_SERVER_TIMEOUT_NORMAL=600000

# 모델 서버 재시도 전 대기 시간 (밀리초, 기본값: 1000ms = 1초)
# MODEL_SERVER_RETRY_DELAY=1000

# Docker 외부 포트 설정 (기본값: 3000)
# 호스트의 다른 포트로 노출하려면 이 값을 변경하세요 (예: 8080, 80)
# EXTERNAL_PORT=3000

# 업로드 경로에 영향 주는 공개 설정이 있다면 여기 추가 (예: NEXT_PUBLIC_*)
# NEXT_PUBLIC_API_BASE=/

