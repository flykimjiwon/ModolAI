{
  "name": "modolai",
  "version": "0.1.0",
  "description": "ModolAI - Open-source self-hosted AI chat and agent platform",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-safe.js",
    "dev:turbopack": "cross-env NODE_ENV=development next dev --turbopack",
    "build": "cross-env NODE_ENV=production SKIP_DB_CONNECTION=true npx next build",
    "build:dev": "cross-env NODE_ENV=development SKIP_DB_CONNECTION=true npx next build --turbopack",
    "build:prod": "cross-env NODE_ENV=production SKIP_DB_CONNECTION=true npx next build",
    "start": "cross-env NODE_ENV=production next start",
    "start:dev": "cross-env NODE_ENV=development next start",
    "start:prod": "cross-env NODE_ENV=production next start",
    "lint": "eslint",
    "test:ollama": "node scripts/test-ollama-endpoints.js",
    "create-admin": "node scripts/create-admin.js",
    "create-admin:interactive": "node scripts/create-admin.js --interactive",
    "setup-postgres": "node scripts/create-postgres-schema.js",
    "test-postgres": "node scripts/test-postgres-connection.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/postcss": "^4",
    "@uiw/react-markdown-preview": "^5.1.5",
    "@uiw/react-md-editor": "^4.0.8",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.542.0",
    "next": "15.5.9",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "recharts": "^3.2.0",
    "rehype-sanitize": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "winston": "3.17.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@10.8.2"
}
